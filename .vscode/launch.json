{
    "version": "0.2.0",
    "configurations": [
        {
            "name": "Debug simulador",
            "type": "cppdbg",
            "request": "launch",
            // Executavel gerado pela task "build simulador".
            // No Windows o gcc/MinGW cria "simulador.exe"; no Linux/macOS, "simulador".
            // O VS Code aceita o caminho sem extensao e encontra o .exe no Windows.
            "program": "${workspaceFolder}/simulador.exe",
            "args": [],
            "stopAtEntry": false,
            "cwd": "${workspaceFolder}",
            // Console externo: necessario porque o programa LE do teclado
            // (digitar o nome/caminho do arquivo e o modo a/b).
            "externalConsole": true,
            "MIMode": "gdb",
            "miDebuggerPath": "gdb",
            // Compila automaticamente antes de iniciar o debug.
            "preLaunchTask": "build simulador",
            "setupCommands": [
                {
                    "description": "Habilita pretty-printing do gdb",
                    "text": "-enable-pretty-printing",
                    "ignoreFailures": true
                }
            ]
        }
    ]
}
